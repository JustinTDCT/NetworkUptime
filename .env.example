SERVER_ADDRESS=https://localhost:8443
SERVER_PORT=8443
SERVER_AGENT_KEY=00000000-0000-4000-8000-000000000001
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
PUBLIC_READ_ONLY=false
ALERT_WEBHOOK_URL=

AGENT_NAME=Local Agent
AGENT_DESCRIPTION=Local Docker agent
AGENT_SERVER_URL=https://server:8443
AGENT_CHECK_IN_INTERVAL_SECONDS=60

# The Docker Compose defaults use a development self-signed certificate.
# Set this to 1 only for local development with that certificate.
NODE_TLS_REJECT_UNAUTHORIZED=0
