{
  "name": "networkuptime",
  "private": true,
  "description": "Docker-based network uptime monitoring server and agent.",
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @networkuptime/server dev",
    "dev:agent": "pnpm --filter @networkuptime/agent dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @networkuptime/db prisma:generate",
    "prisma:push": "pnpm --filter @networkuptime/db prisma:push",
    "prisma:migrate:dev": "pnpm --filter @networkuptime/db prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @networkuptime/db prisma:migrate:deploy",
    "backup:sqlite": "node scripts/backup-sqlite.mjs"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
